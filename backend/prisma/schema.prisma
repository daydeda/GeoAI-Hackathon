// ============================================================
// GEOAI Hackathon Platform — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Identity ─────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  fullName       String
  avatarUrl      String?
  oauthProvider  String   @default("google")
  oauthSubject   String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  userRoles      UserRole[]
  ledTeams       Team[]         @relation("TeamLeader")
  teamMembers    TeamMember[]
  judgeScores    JudgeScore[]
  moderatorReviews ModeratorReview[]
  auditLogs      AuditLog[]     @relation("AuditActor")

  @@map("users")
}

model Role {
  id          String     @id @default(uuid())
  name        RoleType   @unique
  description String?
  userRoles   UserRole[]

  @@map("roles")
}

enum RoleType {
  COMPETITOR
  MODERATOR
  JUDGE
  ADMIN
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  assignedAt DateTime @default(now())
  assignedBy String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

// ─── Teams & Invites ─────────────────────────────────────────

model Team {
  id            String      @id @default(uuid())
  name          String      @unique
  institution   String
  track         Track
  currentStatus TeamStatus  @default(DRAFT)
  leaderId      String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  leader        User         @relation("TeamLeader", fields: [leaderId], references: [id])
  members       TeamMember[]
  invites       Invite[]
  submissions   Submission[]
  statusHistory TeamStatusHistory[]
  documents     Document[]
  scoreAggregates ScoreAggregate[]

  @@map("teams")
}

enum Track {
  SMART_AGRICULTURE
  DISASTER_FLOOD_RESPONSE
}

enum TeamStatus {
  DRAFT
  SUBMITTED
  PRE_SCREEN_PASSED
  JUDGED
  FINALIST
  REJECTED
}

model TeamMember {
  id       String   @id @default(uuid())
  teamId   String
  userId   String
  joinedAt DateTime @default(now())

  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model Invite {
  id        String    @id @default(uuid())
  teamId    String
  code      String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  revoked   Boolean   @default(false)

  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("invites")
}

// ─── Submissions ─────────────────────────────────────────────

model Submission {
  id              String    @id @default(uuid())
  teamId          String
  version         Int       @default(1)
  isActive        Boolean   @default(true)
  gistdaDeclared  Boolean   @default(false)
  abstract        String?   // Summarized content of the proposal PDF
  submittedAt     DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  team            Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  files           SubmissionFile[]
  moderatorReview ModeratorReview?
  judgeScores     JudgeScore[]
  scoreAggregate  ScoreAggregate?

  @@map("submissions")
}

model SubmissionFile {
  id            String   @id @default(uuid())
  submissionId  String
  fileKey       String   // MinIO object key
  fileUrl       String?  // signed URL (transient)
  fileSizeBytes Int
  mimeType      String   @default("application/pdf")
  originalName  String
  uploadedAt    DateTime @default(now())

  submission    Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("submission_files")
}

// ─── Moderator Review ────────────────────────────────────────

model ModeratorReview {
  id           String          @id @default(uuid())
  submissionId String          @unique
  reviewerId   String
  status       ReviewStatus
  note         String?
  reviewedAt   DateTime        @default(now())

  submission   Submission      @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer     User            @relation(fields: [reviewerId], references: [id])

  @@map("moderator_reviews")
}

enum ReviewStatus {
  PASS
  FAIL
}

// ─── Judge Scoring ───────────────────────────────────────────

model JudgeScore {
  id                          String     @id @default(uuid())
  submissionId                String
  judgeUserId                 String
  nationalImpactScore         Float      // 0-100, weight 0.40
  technologyMethodologyScore  Float      // 0-100, weight 0.30
  requirementComplianceScore  Float      // 0-100, weight 0.15
  feasibilityScore            Float      // 0-100, weight 0.15
  comments                    String?
  scoredAt                    DateTime   @default(now())
  updatedAt                   DateTime   @updatedAt

  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  judge        User       @relation(fields: [judgeUserId], references: [id])

  @@unique([submissionId, judgeUserId])
  @@map("judge_scores")
}

model ScoreAggregate {
  id             String   @id @default(uuid())
  submissionId   String   @unique
  teamId         String
  totalWeighted  Float
  judgeCount     Int
  calculatedAt   DateTime @default(now())

  submission     Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  team           Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("score_aggregates")
}

// ─── Team Status History ─────────────────────────────────────

model TeamStatusHistory {
  id        String     @id @default(uuid())
  teamId    String
  fromStatus TeamStatus?
  toStatus  TeamStatus
  actorId   String?
  note      String?
  changedAt DateTime   @default(now())

  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("team_status_history")
}

// ─── Finalist Documents ──────────────────────────────────────

model Document {
  id          String       @id @default(uuid())
  teamId      String
  type        DocumentType @default(PERMISSION_LETTER)
  fileKey     String       // MinIO object key
  generatedAt DateTime     @default(now())
  version     Int          @default(1)

  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("documents")
}

enum DocumentType {
  PERMISSION_LETTER
}

// ─── Exports ─────────────────────────────────────────────────

model Export {
  id          String     @id @default(uuid())
  requestedBy String
  type        ExportType
  fileKey     String?
  status      ExportStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  completedAt DateTime?

  @@map("exports")
}

enum ExportType {
  USERS
  TEAMS
  SUBMISSIONS
  SCORES
}

enum ExportStatus {
  PENDING
  COMPLETE
  FAILED
}

// ─── Audit Logs ──────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String   // e.g. "ROLE_ASSIGNED", "TEAM_STATUS_CHANGED"
  entityType String   // e.g. "user", "team", "submission"
  entityId   String
  oldValue   String?  // JSON string
  newValue   String?  // JSON string
  metadata   String?  // JSON string
  createdAt  DateTime @default(now())

  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}
