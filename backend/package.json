{
  "name": "geoai-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "GEOAI Hackathon Platform API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:grant-admins": "tsx prisma/grant-admins.ts",
    "db:studio": "prisma studio",
    "db:studio:ssh": "prisma studio --browser none --hostname 0.0.0.0 --port 5555",
    "db:reset": "prisma migrate reset --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.3",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.3.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "^6.5.0",
    "exceljs": "^4.4.0",
    "fastify": "^5.3.2",
    "googleapis": "^144.0.0",
    "minio": "^8.0.3",
    "nanoid": "^5.1.5",
    "nodemailer": "^8.0.4",
    "pdf-lib": "^1.17.1",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/nodemailer": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
