# ==========================================
# GEOAI Hackathon Platform — Root Environment
# ==========================================
# Copy this to .env and fill in your values.
# Never commit .env to version control.

# Google OAuth (create at https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# JWT / Cookie secrets (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-jwt-secret
COOKIE_SECRET=change-me-cookie-secret

# MinIO credentials
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Competition
SUBMISSION_DEADLINE_ISO=2026-05-01T23:59:59+07:00
