# ==========================================
# GEOAI Hackathon Platform — Root Environment
# ==========================================
# Copy this to .env / .env.production and fill in your values.
# Never commit real secrets to version control.

# URLs
# IMPORTANT: Do NOT append /api/v1 to NEXT_PUBLIC_API_URL.
# Frontend code already appends /api/v1 to backend calls.
NEXT_PUBLIC_API_URL=https://your-domain.example/geoai-2026
FRONTEND_URL=https://your-domain.example/geoai-2026
# Set this when deploying under a subpath (leave empty for root '/').
NEXT_PUBLIC_BASE_PATH=/geoai-2026
# Admin management URLs (server-side only; not exposed as NEXT_PUBLIC).
# DATABASE_MANAGEMENT_URL can be reverse-proxied Prisma Studio endpoint.
# STORAGE_MANAGEMENT_URL must point to MinIO Console (port 9001 route), not MinIO API (9000).
DATABASE_MANAGEMENT_URL=https://cegs.kmitl.ac.th/geoai-2026/admin/prisma-studio
STORAGE_MANAGEMENT_URL=https://cegs.kmitl.ac.th/geoai-2026/admin/minio

# PostgreSQL
POSTGRES_USER=geoai
POSTGRES_PASSWORD=change-me
POSTGRES_DB=geoai
DATABASE_URL=postgresql://geoai:change-me@db:5432/geoai

# Google OAuth (create at https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=https://your-domain.example/geoai-2026/api/v1/auth/google/callback

# JWT / Cookie secrets (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-secret
COOKIE_SECRET=change-me-to-another-secret
# true for HTTPS production, false for local HTTP
COOKIE_SECURE=true

# MinIO
MINIO_ENDPOINT=storage
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=geoai-files

# App runtime
NODE_ENV=production
LOG_LEVEL=info
SUBMISSION_DEADLINE_ISO=2026-04-29T23:59:59+07:00

# Optional: auto-grant ADMIN role on login for these emails (comma-separated)
ADMIN_EMAIL_ALLOWLIST=admin@example.com

# Gmail SMTP (Announcement Email)
# Use App Password for SMTP_PASS when 2FA is enabled on Gmail.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=admin@gmail.com
# SMTP_PASS=your-app-password
SMTP_FROM="GeoAI Hackathon <admin@gmail.com>"
# Optional OAuth2 mode (if set, SMTP_PASS is not required)
SMTP_REFRESH_TOKEN=
