# ==========================================
# GEOAI Hackathon Platform — Root Environment
# ==========================================
# Copy this to .env and fill in your values.
# Never commit .env to version control.

# Google OAuth (create at https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# JWT / Cookie secrets (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-jwt-secret
COOKIE_SECRET=change-me-cookie-secret

# MinIO credentials
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Competition
SUBMISSION_DEADLINE_ISO=2026-05-01T23:59:59+07:00

# Optional: auto-grant ADMIN role on login for these emails (comma-separated)
ADMIN_EMAIL_ALLOWLIST=jirapoom.bu@kmitl.ac.th,cegs@kmitl.ac.th,napat.tongkasem@gmail.com,pornchai.su@kmitl.ac.th,pornchai.supnithi@gmail.com,daydedaa@gmail.com

# Production URLs
# IMPORTANT: Do NOT append /api/v1 to NEXT_PUBLIC_API_URL.
# Frontend code already appends /api/v1 to all backend calls.
NEXT_PUBLIC_API_URL=https://cegs.kmitl.ac.th/geoai-2026
FRONTEND_URL=https://cegs.kmitl.ac.th/geoai-2026
GOOGLE_CALLBACK_URL=https://cegs.kmitl.ac.th/geoai-2026/api/v1/auth/google/callback
